# =============================================================================
# UPSC Hindi Peer Network — Environment Configuration (EXAMPLE)
# Copy to .env and fill in the values. Never commit .env to git.
# Non-sensitive constants (gamification points etc.) live in app/constants.py.
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
# Option A — local Docker Postgres (default, use with: docker compose --profile local-db up)
DATABASE_URL=postgresql://postgres:postgres@db:5432/upsc_hindi

# Option B — Supabase (recommended for production)
# 1. Create a project at https://supabase.com
# 2. Settings → Database → Connection string → URI → Session pooler (port 5432)
# 3. Run server/scripts/supabase_setup.sql in Supabase SQL Editor
# 4. Run: cd server && alembic upgrade head
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# DATABASE_SSL_MODE=require

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Security ─────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=*

# ─── Demo data seeding ────────────────────────────────────────────────────────
SEED_DEMO_DATA=0

# ─── Current Affairs Automation ───────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
# Must match content_chunks.embedding VECTOR(n) — gemini-embedding-2 defaults to 3072;
# we request 768 via output_dimensionality to match the DB (recommended: 768 or 1536).
GEMINI_EMBEDDING_DIM=768
RSS_FEEDS=https://www.thehindu.com/news/national/feeder/default.rss,https://pib.gov.in/RssMain.aspx,https://indianexpress.com/section/india/feed/
