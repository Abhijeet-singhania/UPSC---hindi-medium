# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/upsc_hindi

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Security (REQUIRED in production — change before deploy) ────────────────
SECRET_KEY=change-me-to-a-long-random-secret

# ─── Demo seed (Docker Compose sets this to 1) ───────────────────────────────
# When 1/true: API creates demo accounts (e.g. priya@demo.drishti.dev) once if missing.
# Set to 0 in production.
SEED_DEMO_DATA=0

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Use * only in development. Set explicit origins in production.
# Example: ALLOWED_ORIGINS=https://app.drishti.in,https://drishti.in
ALLOWED_ORIGINS=*
